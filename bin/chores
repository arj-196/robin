#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="$ROOT/.env"
CANONICAL_REPO="/workspace"
CANONICAL_ROBIN_HOME="/robin-home"
CODEX_VERSION="0.128.0"

require_env_file() {
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "Missing .env file at $ENV_FILE" >&2
    exit 1
  fi
}

load_env() {
  require_env_file
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
}

append_env_file_vars() {
  local target_args="$1"
  local line name value
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$line" || "${line:0:1}" == "#" ]] && continue
    [[ "$line" == export[[:space:]]* ]] && line="${line#export }"
    name="${line%%=*}"
    name="${name%"${name##*[![:space:]]}"}"
    if [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      value="${!name-}"
      eval "$target_args+=(--env \"\$name=\$value\")"
    fi
  done < "$ENV_FILE"
}

resolve_path() {
  local value="$1"
  python3 - "$value" <<'PY'
import os
import sys
print(os.path.abspath(os.path.expandvars(os.path.expanduser(sys.argv[1]))))
PY
}

docker_image_exists() {
  docker image inspect "$1" >/dev/null 2>&1
}

ensure_image() {
  local image="$1"
  local dockerfile="$2"
  if docker_image_exists "$image"; then
    return
  fi

  docker build \
    --build-arg "CODEX_VERSION=$CODEX_VERSION" \
    -t "$image" \
    -f "$dockerfile" \
    "$ROOT"
}

run_docker() {
  load_env

  local image="robin-chores"
  local dockerfile="$ROOT/abilities/services/chores/Dockerfile"
  local robin_home="${ROBIN_HOME:-.robin}"
  local host_robin_home
  host_robin_home="$(resolve_path "$robin_home")"
  mkdir -p "$host_robin_home"

  local docker_args=(
    run
    --rm
    --volume "$ROOT:$CANONICAL_REPO:ro"
    --volume "$host_robin_home:$CANONICAL_ROBIN_HOME:rw"
    --volume "$HOME/.codex:/root/.codex:rw"
    --workdir "$CANONICAL_REPO"
  )
  append_env_file_vars docker_args
  docker_args+=(
    --env "ROBIN_HOME=$CANONICAL_ROBIN_HOME"
    --env "HOME=/root"
    --env "ROBIN_CONTAINER_DIRECT_PYTHON=1"
  )

  ensure_image "$image" "$dockerfile"
  exec docker "${docker_args[@]}" "$image" python abilities/services/chores/src/main.py "$@"
}

exec_docker() {
  load_env

  local image="robin-chores"
  local dockerfile="$ROOT/abilities/services/chores/Dockerfile"
  local robin_home="${ROBIN_HOME:-.robin}"
  local host_robin_home
  host_robin_home="$(resolve_path "$robin_home")"
  mkdir -p "$host_robin_home"

  local docker_args=(
    run
    --rm
    -it
    --volume "$ROOT:$CANONICAL_REPO:ro"
    --volume "$host_robin_home:$CANONICAL_ROBIN_HOME:rw"
    --volume "$HOME/.codex:/root/.codex:rw"
    --workdir "$CANONICAL_REPO"
  )
  append_env_file_vars docker_args
  docker_args+=(
    --env "ROBIN_HOME=$CANONICAL_ROBIN_HOME"
    --env "HOME=/root"
    --env "ROBIN_CONTAINER_DIRECT_PYTHON=1"
  )

  ensure_image "$image" "$dockerfile"
  if [[ $# -eq 0 ]]; then
    exec docker "${docker_args[@]}" "$image" /bin/sh
  fi
  exec docker "${docker_args[@]}" "$image" "$@"
}

if [[ "${1:-}" == "install-cron" ]]; then
  shift
  schedule="*/5 8-10 * * *"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --schedule)
        schedule="${2:?Missing value for --schedule}"
        shift 2
        ;;
      --schedule=*)
        schedule="${1#--schedule=}"
        shift
        ;;
      *)
        echo "Unknown install-cron option: $1" >&2
        exit 1
        ;;
    esac
  done
  printf '%s cd %s && %s/bin/chores run\n' "$schedule" "$ROOT" "$ROOT"
  exit
fi

if [[ "${1:-}" == "exec" ]]; then
  shift
  exec_docker "$@"
fi

run_docker "$@"
