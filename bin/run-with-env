#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if [[ ! -f .env ]]; then
  echo "Missing .env file at $ROOT/.env" >&2
  exit 1
fi

set -a
. ./.env
set +a

# PATH is sourced from .env when defined there. This is intentional so cron
# executions can use the same command resolution as interactive shells.
exec "$@"
