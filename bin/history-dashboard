#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="$ROOT/.env"
CANONICAL_REPO="/workspace"
CANONICAL_ROBIN_HOME="/robin-home"

usage() {
  cat <<'TEXT'
Usage: ./bin/history-dashboard <mode> [options]

Modes:
  build     Build the Docker image
  status    Print health payload JSON
  serve     Start production Next.js dashboard in Docker
  dev       Start Next.js dev server in Docker with hot reload
  help      Show this help

Serve options:
  --background, -d  Run the dashboard in a detached Docker container
TEXT
}

require_env_file() {
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "Missing .env file at $ENV_FILE" >&2
    exit 1
  fi
}

load_env() {
  require_env_file
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
}

append_env_file_vars() {
  local target_args="$1"
  local line name value
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$line" || "${line:0:1}" == "#" ]] && continue
    [[ "$line" == export[[:space:]]* ]] && line="${line#export }"
    name="${line%%=*}"
    name="${name%"${name##*[![:space:]]}"}"
    if [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      value="${!name-}"
      eval "$target_args+=(--env \"\$name=\$value\")"
    fi
  done < "$ENV_FILE"
}

resolve_path() {
  local value="$1"
  python3 - "$value" <<'PY'
import os
import sys
print(os.path.abspath(os.path.expandvars(os.path.expanduser(sys.argv[1]))))
PY
}

docker_image_exists() {
  docker image inspect "$1" >/dev/null 2>&1
}

ensure_image() {
  local image="$1"
  local dockerfile="$2"
  if docker_image_exists "$image"; then
    return
  fi

  docker build \
    -t "$image" \
    -f "$dockerfile" \
    "$ROOT"
}

run_docker() {
  local mode="${1:-help}"
  shift || true
  local background=0

  case "$mode" in
    help|--help|-h)
      usage
      ;;
    build|status|serve|dev)
      load_env

      if [[ "$mode" == "serve" || "$mode" == "dev" ]]; then
        local passthrough_args=()
        while (($#)); do
          case "$1" in
            --background|-d)
              background=1
              shift
              ;;
            --)
              shift
              passthrough_args+=("$@")
              break
              ;;
            *)
              passthrough_args+=("$1")
              shift
              ;;
          esac
        done
        set +u
        set -- "${passthrough_args[@]}"
        set -u
      fi

      local image="robin-history-dashboard"
      local dockerfile="$ROOT/abilities/apps/history-dashboard/Dockerfile"

      if [[ "$mode" == "build" ]]; then
        exec docker build \
          -t "$image" \
          -f "$dockerfile" \
          "$ROOT" \
          "$@"
      fi

      local port="${HISTORY_DASHBOARD_PORT:-3000}"
      local robin_home="${ROBIN_HOME:-.robin}"
      local host_robin_home
      host_robin_home="$(resolve_path "$robin_home")"
      mkdir -p "$host_robin_home"

      ensure_image "$image" "$dockerfile"

      local docker_args=(
        run
        --rm
        --init
      )
      if [[ "$mode" == "serve" || "$mode" == "dev" ]]; then
        docker_args+=(--publish "$port:$port")
        if ((background)); then
          docker_args+=(
            --detach
            --name robin-history-dashboard
          )
        fi
      fi
      if [[ "$mode" == "dev" ]]; then
        docker_args+=(
          --volume "$ROOT:$CANONICAL_REPO:rw"
          --volume "robin-history-dashboard-node-modules:$CANONICAL_REPO/abilities/apps/history-dashboard/web/node_modules"
          --volume "$host_robin_home:$CANONICAL_ROBIN_HOME:ro"
          --workdir "$CANONICAL_REPO/abilities/apps/history-dashboard/web"
        )
      else
        docker_args+=(
          --volume "$host_robin_home:$CANONICAL_ROBIN_HOME:ro"
          --workdir "$CANONICAL_REPO/abilities/apps/history-dashboard/web"
        )
      fi
      append_env_file_vars docker_args
      docker_args+=(
        --env "ROBIN_HOME=$CANONICAL_ROBIN_HOME"
        --env "PORT=$port"
      )
      if [[ "$mode" == "dev" ]]; then
        docker_args+=(
          --env "NODE_ENV=development"
          --env "WATCHPACK_POLLING=true"
        )
      fi

      if [[ "$mode" == "status" ]]; then
        exec docker "${docker_args[@]}" \
          "$image" \
          node /usr/local/bin/history-dashboard-status.js
      fi

      if [[ "$mode" == "dev" ]]; then
        local dev_cmd='if [ ! -f node_modules/.package-lock.json ]; then npm ci; fi; ./node_modules/.bin/next dev --hostname 0.0.0.0 --port "$PORT"'
        if ((background)); then
          docker "${docker_args[@]}" \
            "$image" \
            bash -lc "$dev_cmd"
          echo "History dashboard dev server is running in the background on http://localhost:$port"
          echo "Stop it with: docker stop robin-history-dashboard"
          return
        fi

        exec docker "${docker_args[@]}" \
          "$image" \
          bash -lc "$dev_cmd"
      fi

      if ((background)); then
        docker "${docker_args[@]}" \
          "$image" \
          ./node_modules/.bin/next start --hostname 0.0.0.0 --port "$port" "$@"
        echo "History dashboard is running in the background on http://localhost:$port"
        echo "Stop it with: docker stop robin-history-dashboard"
        return
      fi

      exec docker "${docker_args[@]}" \
        "$image" \
        ./node_modules/.bin/next start --hostname 0.0.0.0 --port "$port" "$@"
      ;;
    *)
      echo "Unknown mode: $mode" >&2
      exit 1
      ;;
  esac
}

run_docker "$@"
