# Connector abilities
NOTION_API_KEY=secret_notion_token
NOTION_TASK_DATABASE_ID=example-task-database-id
NOTION_PARENT_PAGE_ID=example-parent-page-id

# Service abilities
APPS_ROOT=~/apps
AUTO_CODER_STATUS_PROPERTY=Status
AUTO_CODER_PROJECT_PROPERTY=Project
AUTO_CODER_ERROR_LOG_PROPERTY="Error Log"
AUTO_CODER_CODEX_MODEL=gpt-5.3-codex
AUTO_CODER_GIT_COMPLETION_MODE=auto_merge_main
OPENROUTER_API_KEY=sk-or-v1-example
AUTO_CODER_COMMIT_MODEL=openai/gpt-oss-120b
AUTO_CODER_COMMIT_MAX_CONTEXT_TOKENS=100000

CHORES_TIMEZONE=Europe/Paris
CHORES_STATE_FILE=.robin/chores-state.json
CHORES_CODEX_INIT_COMMAND='codex exec "Reply with exactly: ok"'

# App abilities
DASHBOARD_PORT=3000
