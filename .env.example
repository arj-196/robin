# Cron related
# -----------------------------
# Cron/runtime path (set this to match your interactive shell so tools like `uv` are found)
PATH=/usr/local/bin:/usr/bin:/bin

# Log related
# -----------------------------
ROBIN_LOG_LEVEL=DEBUG

# Connector abilities
# -----------------------------

# Notion
NOTION_API_KEY=secret_notion_token
NOTION_TASK_DATABASE_ID=example-task-database-id
NOTION_PARENT_PAGE_ID=example-parent-page-id

# Service abilities
# -----------------------------

# History and logging
ROBIN_HOME=.robin
ROBIN_RUN_LEDGER_DIR=run-ledger
ROBIN_LOG_RUNS_DIR=logs
ROBIN_TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
ROBIN_TELEGRAM_CHAT_ID=123456789
# Auto Coder
AUTO_CODER_APPS_ROOT=~/apps
AUTO_CODER_LOCKS_DIR=locks
AUTO_CODER_STATUS_PROPERTY=Status
AUTO_CODER_PROJECT_PROPERTY=Project
AUTO_CODER_ERROR_LOG_PROPERTY="Error Log"
AUTO_CODER_CODEX_MODEL=gpt-5.3-codex
AUTO_CODER_GIT_COMPLETION_MODE=auto_merge_main
OPENROUTER_API_KEY=sk-or-v1-example
AUTO_CODER_COMMIT_MODEL=openai/gpt-oss-120b
AUTO_CODER_COMMIT_MAX_CONTEXT_TOKENS=100000
# SSH auth (placeholder values only; keep real keys in .env or secret manager)
AUTO_CODER_GITHUB_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n<replace-with-private-key>\n-----END OPENSSH PRIVATE KEY-----"
AUTO_CODER_GITHUB_SSH_PUBLIC_KEY="ssh-ed25519 <replace-with-public-key>"

# Chores
CHORES_TIMEZONE=Europe/Paris
CHORES_STATE_FILE=state/chores-state.json
CHORES_CODEX_INIT_COMMAND='codex exec "Reply with exactly: ok"'

# App abilities
# -----------------------------

# History Dashboard
HISTORY_DASHBOARD_PORT=3000
HISTORY_DASHBOARD_AUTH_USERNAME=
HISTORY_DASHBOARD_AUTH_PASSWORD=
